{
  "name": "localcut-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-ort-wasm.mjs",
    "electron:dev": "vite --config vite.electron.config.ts",
