    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^39.8.10",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.3",
    "vite": "^6.2.4",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vue-tsc": "^2.2.8"
